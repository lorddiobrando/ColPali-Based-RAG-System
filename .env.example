FLASK_APP=app:create_app
FLASK_ENV=development
HOST=127.0.0.1
PORT=5000

# Data paths
DATA_DIR=./data
HF_CACHE_DIR=./data/cache/huggingface
VIDORE_DATASET=vidore/vidore-benchmark

# Output artifacts
VIDORE_OUTPUT_DIR=./data/processed/vidore
VIDORE_MANIFEST_PATH=./data/processed/vidore/vidore_manifest.jsonl

# Encoder
COLPALI_MODEL=vidore/colSmol-256M
ENCODER_TYPE=colpali

# Qdrant (local file-based)
QDRANT_PATH=./data/indexes/qdrant
QDRANT_COLLECTION=vidore_pages

# OpenRouter (set your key to enable RAG generation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it
